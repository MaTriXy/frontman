---
// Full Context Section
// ------------
// Description: A section explaining how Frontman provides full context to the AI agent

// Components
// - Layout
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - Images
import devServerSvg from '../../../assets/context/dev-server.svg'
import clientSvg from '../../../assets/context/client.svg'
---

<section id="full-context" class="full-context-section">
	<div class="container">
		<Row classes="gap-12">
			<!-- Left side: Visual -->
			<Col spanMobile="12" span="6">
				<div class="context-visual">
					<div class="server-client-diagram">
						<!-- Dev Server -->
						<div class="diagram-item">
							<img src="/logo.svg" alt="Frontman" class="diagram-logo" width="64" height="64" loading="lazy" />
							<div class="illustration-wrapper">
								<div class="scan-line"></div>
							<img src={devServerSvg.src} alt="Dev Server" class="illustration-image" width="264" height="295" loading="lazy" />
							</div>
							<p class="diagram-label">Dev Server</p>
						</div>

						<!-- Client -->
						<div class="diagram-item">
							<img src="/logo.svg" alt="Frontman" class="diagram-logo" width="64" height="64" loading="lazy" />
							<div class="illustration-wrapper">
								<div class="scan-line"></div>
							<img src={clientSvg.src} alt="Client" class="illustration-image" width="264" height="295" loading="lazy" />
							</div>
							<p class="diagram-label">Client</p>
						</div>
					</div>
				</div>
			</Col>

			<!-- Right side: Content -->
			<Col spanMobile="12" span="6">
				<div class="context-content">
					<h2 class="context-title">
						Other AI Tools Guess.<br/>Frontman Sees.
					</h2>

					<div class="context-text">
						<p>
							Cursor, Claude Code, Copilot — they all run in your terminal or IDE, completely disconnected from what's rendering in your browser. They read your code, but they've never seen your UI.
						</p>
						<p>
							Frontman's agent connects to both your dev server and your browser. It has direct access to your DOM, styles, and component tree in real time. That means fewer hallucinations, faster iterations, and code that matches your intent on the first try.
						</p>
					</div>
				</div>
			</Col>
		</Row>
	</div>
</section>

<style>
	.full-context-section {
		@apply relative overflow-hidden py-20 lg:py-32;
		background-color: #1a1a1a;
		background-image:
			repeating-linear-gradient(
				60deg,
				transparent,
				transparent 50px,
				rgba(162, 89, 255, 0.15) 50px,
				rgba(162, 89, 255, 0.15) 51px
			),
			repeating-linear-gradient(
				-60deg,
				transparent,
				transparent 50px,
				rgba(162, 89, 255, 0.15) 50px,
				rgba(162, 89, 255, 0.15) 51px
			);
		background-size: 100px 100px;
	}

	.container {
		@apply relative mx-auto px-6 max-w-7xl;
	}

	/* Visual Side */
	.context-visual {
		@apply relative flex items-center justify-center;
		min-height: 400px;
	}

	.server-client-diagram {
		@apply relative flex flex-row items-end justify-center;
		width: 100%;
		max-width: 600px;
		gap: 1.5rem;
	}

	@media (min-width: 768px) {
		.server-client-diagram {
			gap: 2rem;
		}
	}

	.diagram-item {
		@apply relative flex flex-col items-center;
		flex: 1;
		min-width: 0;
	}

	/* Logo sits in-flow above the illustration, overlapping it with negative margin */
	.diagram-logo {
		width: 48px;
		height: 48px;
		margin-bottom: -24px;
		z-index: 40;
		position: relative;
		filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.25));
	}

	@media (min-width: 768px) {
		.diagram-logo {
			width: 80px;
			height: 80px;
			margin-bottom: -40px;
		}
	}

	.illustration-wrapper {
		@apply relative overflow-hidden;
		width: 100%;
	}

	.illustration-image {
		@apply w-full h-auto;
		display: block;
	}

	.scan-line {
		@apply absolute left-0 right-0;
		height: 2px;
		background: linear-gradient(90deg, transparent, #A259FF, transparent);
		animation: scan 2s ease-in-out infinite;
		top: 0;
		z-index: 30;
	}

	@keyframes scan {
		0% {
			top: 0;
			opacity: 0;
		}
		50% {
			opacity: 1;
		}
		100% {
			top: 100%;
			opacity: 0;
		}
	}

	.diagram-label {
		@apply font-headings text-xl font-bold text-white mt-3;
	}

	/* Content Side */
	.context-content {
		@apply flex flex-col justify-center h-full py-8 lg:py-0;
	}

	.context-title {
		@apply font-headings text-4xl lg:text-5xl font-bold mb-8;
		color: white;
		line-height: 1.2;
	}

	.title-line {
		@apply block;
	}

	.context-text {
		@apply space-y-4;
	}

	.context-text p {
		@apply text-base lg:text-lg leading-relaxed;
		color: rgba(255, 255, 255, 0.9);
	}

	/* Responsive adjustments */
	@media (max-width: 1024px) {
		.context-visual {
			min-height: auto;
		}

		.server-client-diagram {
			max-width: 450px;
		}

		.diagram-label {
			@apply text-lg;
		}

		.context-title {
			@apply text-3xl mb-6;
		}

		.context-text p {
			@apply text-base;
		}
	}

	@media (max-width: 640px) {
		.full-context-section {
			padding-top: 2rem;
			padding-bottom: 2rem;
		}

		.server-client-diagram {
			max-width: 100%;
			gap: 1rem;
		}

		.diagram-label {
			@apply text-sm;
		}

		.context-title {
			@apply text-2xl mb-5;
		}
	}
</style>
